# Required secrets (CHANGE FOR PRODUCTION)
JWT_SECRET=change-me
# Must be exactly 32 characters
STORE_ENCRYPTION_KEY=12345678901234567890123456789012
# API key used by the Dashboard (self-hosted) to talk to Novu API
NOVU_SECRET_KEY=nvsk.change-me

# Runtime
NODE_ENV=production

# DB
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=secret
MONGO_URL=mongodb://root:secret@mongodb:27017/novu-db?authSource=admin
MONGO_MIN_POOL_SIZE=50
MONGO_MAX_POOL_SIZE=500
MONGO_AUTO_CREATE_INDEXES=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB_INDEX=2
REDIS_CACHE_SERVICE_HOST=
REDIS_CACHE_SERVICE_PORT=

# Public URLs (these must be reachable by browsers)
# Example:
# API_ROOT_URL=https://api.novu.yourdomain.com
# FRONT_BASE_URL=https://dashboard.novu.yourdomain.com
# DASHBOARD_URL=https://dashboard.novu.yourdomain.com
API_ROOT_URL=http://localhost:3000
FRONT_BASE_URL=http://localhost:4000
DASHBOARD_URL=http://localhost:4000

# Ports (host -> container)
API_PORT=3000
WS_PORT=3002
WORKER_PORT=3004
DASHBOARD_PORT=4000
DOCKER_MONGO_PORT=27017

# Dashboard runtime config (Vite)
VITE_API_HOSTNAME=http://localhost:3000
VITE_WEBSOCKET_HOSTNAME=ws://localhost:3002
VITE_LEGACY_DASHBOARD_URL=

# Observability (optional)
SENTRY_DSN=
NEW_RELIC_ENABLED=false
NEW_RELIC_APP_NAME=
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_WORKER_APP_NAME=
NEW_RELIC_WS_APP_NAME=

# Feature flags (optional)
DISABLE_USER_REGISTRATION=false
GLOBAL_CONTEXT_PATH=
API_CONTEXT_PATH=
WS_CONTEXT_PATH=
IS_API_IDEMPOTENCY_ENABLED=false
IS_API_RATE_LIMITING_ENABLED=false
IS_V2_ENABLED=false

# Storage (recommended in production: configure real S3/GCS/Azure)
S3_LOCAL_STACK=
S3_BUCKET_NAME=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Worker tuning (optional)
BROADCAST_QUEUE_CHUNK_SIZE=100
MULTICAST_QUEUE_CHUNK_SIZE=100
IS_EMAIL_INLINE_CSS_DISABLED=false
IS_USE_MERGED_DIGEST_ID_ENABLED=false
STEP_RESOLVER_DISPATCH_URL=
STEP_RESOLVER_HMAC_SECRET=

# Images (optional)
# If you build/publish your own images (e.g. with your custom providers),
# set these to your registry and tag.
NOVU_IMAGE_TAG=3.14.0
NOVU_API_IMAGE=ghcr.io/novuhq/novu/api
NOVU_WORKER_IMAGE=ghcr.io/novuhq/novu/worker
NOVU_WS_IMAGE=ghcr.io/novuhq/novu/ws
NOVU_DASHBOARD_IMAGE=ghcr.io/novuhq/novu/dashboard

